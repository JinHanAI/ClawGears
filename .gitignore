# OMC State Files (Claude Code internal)
.omc/

# History files (user-specific audit results)
# Keep directory structure but ignore contents
history/*
!history/.gitkeep

# Reports (generated locally)
reports/

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor files
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-*

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp
*.bak
*.cache

# Test coverage
coverage/
.nyc_output/

# Environment files (never commit secrets)
.env
.env.local
.env.*.local
*.pem
*.key
